{
  "name": "prodigy-coder",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "bun --bun oxlint --disable-nested-config",
    "lint-fix": "bun --bun oxlint --disable-nested-config --fix",
    "format": "bun oxfmt --check",
    "format-fix": "bun oxfmt --write",
    "test": "bun --bun vitest",
    "coverage": "bun vitest --coverage",
    "prepare": "husky; effect-language-service patch"
  },
  "lint-staged": {
    "*.{ts}": [
      "bun oxfmt --write",
      "bun --bun oxlint --disable-nested-config --fix",
      "bash -c 'bun run typecheck'",
      "bash -c 'bun run test --run'"
    ]
  },
  "dependencies": {
    "@effect/ai-anthropic": "^4.0.0-beta.50",
    "@effect/ai-openai": "^4.0.0-beta.50",
    "@effect/ai-openai-compat": "^4.0.0-beta.50",
    "@effect/ai-openrouter": "^4.0.0-beta.50",
    "@effect/platform-bun": "^4.0.0-beta.50",
    "effect": "^4.0.0-beta.50"
  },
  "devDependencies": {
    "@effect/language-service": "^0.85.1",
    "@effect/vitest": "^4.0.0-beta.49",
    "@oxlint/plugins": "^1.60.0",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
