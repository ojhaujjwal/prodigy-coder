{
  "ignorePatterns": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/.tsbuildinfo",
    "**/*.md",
    "**/.ralph/**",
    "repos/**"
  ],
  "jsPlugins": ["./lint/index.ts"],
  "rules": {
    "no-explicit-any": "error",
    "typescript/consistent-type-assertions": ["error", { "assertionStyle": "never" }],
    "typescript/no-non-null-assertion": "error",
    "prodigy/no-effect-ignore": "error",
    "prodigy/no-effect-catchallcause": "error",
    "prodigy/no-effect-asvoid": "error",
    "prodigy/no-silent-error-swallow": "error",
    "prodigy/no-service-option": "error",
    "prodigy/no-nested-layer-provide": "error",
    "prodigy/pipe-max-arguments": "error",
    "prodigy/prefer-option-from-nullable": "error",
    "prodigy/import-extensions": "error",
    "prodigy/no-disable-validation": "error",
    "prodigy/no-void-expression": "error",
    "prodigy/no-node-imports": "error",
    "prodigy/no-require": "error",
    "prodigy/no-process": "error",
    "prodigy/no-bun-globals": "error",
    "prodigy/no-console": "error",
    "prodigy/no-plain-it-with-effect": "error",
    "prodigy/no-vitest-modifiers": "error"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts"],
      "rules": {
        "prodigy/no-silent-error-swallow": "off"
      }
    }
  ]
}
